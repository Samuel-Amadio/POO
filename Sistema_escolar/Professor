package sistema_escolar;

import java.util.*;

public class Professor extends Usuario{
	
	ArrayList<Disciplina> disciplinas;
	
	 public Professor(String nome) {
	        this.nome = nome;
	        disciplinas = new ArrayList<>();
	    }

	    public void adicionarDisciplina(Disciplina disciplina) {
	        disciplinas.add(disciplina);
	    }

	    public void visualizarNotasAlunos() {

	        for(Disciplina d : disciplinas) {
	            System.out.println("Disciplina: " + d.getNome());
	            d.verNotas();
	        }
	    }

	    public void adicionarNota(Aluno aluno, double nota1, double nota2, int codigo) {

	        for(Disciplina d : disciplinas) {
	            if(d.getCodigo() == codigo) {
	                d.adicionarNota(aluno, nota1, nota2);
	            }
	        }
	    }
}
